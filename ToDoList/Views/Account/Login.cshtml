@{
    Layout = null;
    ViewBag.Title = "To Do List : Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container" style="margin-top: 80px; max-width: 400px;">
        <h2>Login</h2>

        @if (ViewBag.Error != null)
        {
            <p style="color:red;">@ViewBag.Error</p>
        }

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Username"
                       maxlength="20"
                       pattern="[A-Za-z0-9]+"
                       oninput="this.value = this.value.replace(/\s/g, '')"
                       required />
            </div>

            <div class="form-group" style="margin-top: 10px; position: relative;">
                <input type="password"
                       id="password"
                       name="password"
                       class="form-control"
                       placeholder="Password"
                       required />

                <span onclick="togglePassword()"
                      style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); cursor: pointer;">
                    👁️
                </span>
            </div>

            <div style="margin-top: 15px;">
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
        }

        <div style="margin-top: 15px;">
            <a href="/Account/Signup">Don't have an account? Sign Up</a>
        </div>
    </div>

    <script>
        function togglePassword() {
            var pwd = document.getElementById("password");
            pwd.type = (pwd.type === "password") ? "text" : "password";
        }
    </script>
</body>
</html>