@model IEnumerable<ToDoList.Models.TaskItemModel>

@{
    ViewBag.Title = "ToDoList";
}

<h2 class="text-center">To Do List</h2>

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <div>
            @Html.ActionLink("Add New Task", "Create", null, new { @class = "btn btn-primary" })
        </div>

        <div style="width:300px;">
            <input type="text" id="taskSearch" class="form-control" placeholder="Search..." />
        </div>
    </div>

    <table class="table">
        @foreach (var item in Model)
        {
            var buttonClass = item.Status == "In Progress"
                ? "btn-info"
                : item.Status == "Complete"
                    ? "btn-danger"
                    : "btn-secondary";

        <tr class="task-row">
            <td>
                <input type="checkbox"
                       class="task-checkbox"
                       data-id="@item.Id"
                       @(item.Status == "Complete" ? "checked=\"checked\"" : "") />
            </td>

            <td class="task-title">
                @Html.DisplayFor(modelItem => item.Title)
            </td>

            <td>
                <button class="btn btn-sm toggle-status @buttonClass"
                        data-id="@item.Id"
                        @(item.Status == "Complete" ? "disabled=\"disabled\"" : "")>
                    @item.Status
                </button>
            </td>

            <td>
                <input type="date"
                       class="form-control due-date-input"
                       data-id="@item.Id"
                       style="width: 160px;"
                       value="@(item.DueDate.HasValue ? item.DueDate.Value.ToString("yyyy-MM-dd") : "")" />
            </td>
            <td>
                <select class="form-control category-select" data-id="@item.Id" style="width:150px;">
                    <option value="">Select Category</option>
                    <option value="Work" @(item.Category == "Work" ? "selected" : "")>Work</option>
                    <option value="Study" @(item.Category == "Study" ? "selected" : "")>Study</option>
                    <option value="Personal" @(item.Category == "Personal" ? "selected" : "")>Personal</option>
                    <option value="Urgent" @(item.Category == "Urgent" ? "selected" : "")>Urgent</option>
                </select>
            </td>

            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.Id }) |

                @using (Html.BeginForm("Delete", "TaskItem", new { id = item.Id }, FormMethod.Post, new { style = "display:inline;" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="submit"
                           value="Delete"
                           class="btn btn-link text-danger"
                           style="padding:0;"
                           onclick="return confirm('Are you sure you want to delete this task?');" />
                }
            </td>

            </tr>
         }
    </table>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
    document.querySelectorAll('.toggle-status').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const id = btn.getAttribute('data-id');
            let newStatus = "";

            if (btn.innerText.trim() === "Pending") {
                newStatus = "In Progress";
            } else {
                newStatus = "Pending";
            }

            $.ajax({
                url: '@Url.Action("UpdateStatus", "TaskItem")',
                type: 'POST',
                data: {
                    id: id,
                    status: newStatus
                },
                success: function (response) {
                    if (response.success) {
                        btn.innerText = response.newStatus;
                        btn.classList.remove("btn-secondary", "btn-info", "btn-danger");

                        if (response.newStatus === "In Progress") {
                            btn.classList.add("btn-info");
                        } else if (response.newStatus === "Complete") {
                            btn.classList.add("btn-danger");
                        } else {
                            btn.classList.add("btn-secondary");
                        }
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Error updating status.");
                }
            });
        });
    });

    document.querySelectorAll('.task-checkbox').forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
            const id = checkbox.getAttribute('data-id');
            const btn = document.querySelector('.toggle-status[data-id="' + id + '"]');
            let newStatus = "";

            if (checkbox.checked) {
                newStatus = "Complete";
            } else {
                newStatus = "Pending";
            }

            $.ajax({
                url: '@Url.Action("UpdateStatus", "TaskItem")',
                type: 'POST',
                data: {
                    id: id,
                    status: newStatus
                },
                success: function (response) {
                    if (response.success) {
                        btn.innerText = response.newStatus;
                        btn.classList.remove("btn-secondary", "btn-info", "btn-danger");

                        if (response.newStatus === "Complete") {
                            btn.classList.add("btn-danger");
                            btn.disabled = true;
                            btn.classList.add("disabled");
                        } else if (response.newStatus === "In Progress") {
                            btn.classList.add("btn-info");
                            btn.disabled = false;
                            btn.classList.remove("disabled");
                        } else {
                            btn.classList.add("btn-secondary");
                            btn.disabled = false;
                            btn.classList.remove("disabled");
                        }
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Error updating checkbox status.");
                }
            });
        });
    });

    document.querySelectorAll('.due-date-input').forEach(function (input) {
        input.addEventListener('change', function () {
            const id = input.getAttribute('data-id');
            const dueDate = input.value;

            $.ajax({
                url: '@Url.Action("UpdateDueDate", "TaskItem")',
                type: 'POST',
                data: {
                    id: id,
                    dueDate: dueDate
                },
                success: function (response) {
                    if (!response.success) {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Error updating due date.");
                }
            });
        });
    });


        document.getElementById('taskSearch').addEventListener('keyup', function () {
            const keyword = this.value.toLowerCase().trim();
            const rows = document.querySelectorAll('.task-row');

            rows.forEach(function (row) {
                const title = row.querySelector('.task-title')?.innerText.toLowerCase() || '';
                const status = row.querySelector('.toggle-status')?.innerText.toLowerCase() || '';
                const dueDate = row.querySelector('.due-date-input')?.value.toLowerCase() || '';
                const category = row.querySelector('.category-select')?.value.toLowerCase() || '';
                const rowText = `${title} ${status} ${dueDate} ${category}`;
                row.style.display = rowText.includes(keyword) ? '' : 'none';
            });
        });

    document.querySelectorAll('.category-select').forEach(function (select) {
    select.addEventListener('change', function () {
        const id = select.getAttribute('data-id');
        const category = select.value;

        $.ajax({
            url: '@Url.Action("UpdateCategory", "TaskItem")',
            type: 'POST',
            data: {
                id: id,
                category: category
            },
            success: function (response) {
                if (!response.success) {
                    alert(response.message);
                }
            },
            error: function () {
                alert("Error updating category.");
            }
        });
    });
});
    </script>