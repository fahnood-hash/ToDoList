@model ToDoList.Models.TaskItemModel

@{
    ViewBag.Title = "Create ToDoList";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h2 class="text-center">To Do List</h2>

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group text-center">
            <div style="display: flex; justify-content: center; gap: 15px; max-width: 500px; margin: auto;">
                @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", style = "flex:1;", placeholder = "Enter task title" } })

                <button type="submit" class="btn btn-primary">Add</button>
            </div>

            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
        </div>
    </div>

    @*<div class="form-group">
        @Html.LabelFor(model => model.Category)
        @Html.DropDownListFor(model => model.Category,
            new SelectList(new[] { "Work", "Study", "Personal", "Urgent" }),
            "Select Category",
            new { @class = "form-control" })
    </div>*@
}

<div class="text-center" style="margin-top: 20px;">
    @Html.ActionLink("Back to List", "Index")
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}